# YouTube API setup
# Instructions: Go to Google Cloud Console, create a project, enable YouTube Data API v3, create API Credentials, and put the API key here.
YOUTUBE_API_KEY="paste_your_api_key_here"

# Database Configuration
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="postgres_password"
POSTGRES_DB="yt_stats"

# Database URL for SQLAlchemy
# Format for asyncpg: postgresql+asyncpg://user:password@localhost/dbname
# Format for psycopg2 (sync): postgresql://user:password@localhost/dbname
DATABASE_URL="postgresql://postgres:postgres_password@localhost:5432/yt_stats"
